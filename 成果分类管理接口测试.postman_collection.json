		{
			"name": "5. 状态管理接口",
			"item": [
				{
					"name": "禁用分类",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/lab/achievement-categories/18/status?active=false",
							"host": ["{{baseUrl}}"],
							"path": ["lab", "achievement-categories", "18", "status"],
							"query": [
								{
									"key": "active",
									"value": "false"
								}
							]
						}
					}
				},
				{
					"name": "启用分类",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/lab/achievement-categories/18/status?active=true",
							"host": ["{{baseUrl}}"],
							"path": ["lab", "achievement-categories", "18", "status"],
							"query": [
								{
									"key": "active",
									"value": "true"
								}
							]
						}
					}
				}
			]
		},
		{
			"name": "6. 删除测试接口",
			"item": [
				{
					"name": "删除测试分类",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/lab/achievement-categories/{{testCategoryId}}",
							"host": ["{{baseUrl}}"],
							"path": ["lab", "achievement-categories", "{{testCategoryId}}"]
						}
					}
				}
			]
		},
		{
			"name": "7. 错误测试用例",
			"item": [
				{
					"name": "测试重复编码",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"parentId\": null,\n    \"categoryCode\": \"PAPER\",\n    \"categoryName\": \"重复编码测试\",\n    \"description\": \"测试重复编码\",\n    \"sortOrder\": 1\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/lab/achievement-categories",
							"host": ["{{baseUrl}}"],
							"path": ["lab", "achievement-categories"]
						}
					}
				},
				{
					"name": "测试无效父分类",
